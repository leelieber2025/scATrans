# Source distribution (sdist) contents for PyPI / GitHub source installs.
# The *wheel* only ships the runtime package (src/scatrans + package data) —
# controlled by [tool.setuptools.packages.find] + package-data, not this file.

# Project metadata
include LICENSE
include README.md
include CHANGELOG.md
include CITATION.cff
include SECURITY.md
include pyproject.toml
include setup.cfg
include MANIFEST.in
include .gitignore
include .pre-commit-config.yaml
include .readthedocs.yaml

# Test suite (run from sdist: pytest)
include conftest.py
include conftest_fixtures.py
graft tests

# Documentation sources (not built HTML)
graft docs
prune docs/_build

# Examples & packaging helpers
graft examples
graft packaging

# CI workflows
graft .github/workflows

# Never ship
recursive-exclude src/scatrans.egg-info *
prune build
prune dist
prune backup
prune .git
prune .mypy_cache
prune .pytest_cache
prune .ruff_cache
prune .tox
prune htmlcov
global-exclude *.pyc
global-exclude __pycache__/*
global-exclude *.egg-info
global-exclude *.egg-info/*
global-exclude *.h5ad
global-exclude *.zip
global-exclude .DS_Store

# Pre-split monorepo modules must not re-enter (shadow real packages)
global-exclude src/scatrans/tl.py
global-exclude src/scatrans/enrich.py
