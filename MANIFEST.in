# Control what goes into the source distribution (sdist).
# The wheel only contains the runtime package (src/scatrans + data).

# Standard important files
include LICENSE
include README.md
include CHANGELOG.md
include CITATION.cff
include pyproject.toml
include conftest.py
include conftest_fixtures.py

# Include the full test suite so that `pytest` can be run from sdist/unpacked source
graft tests

# Include the GitHub Actions workflows (requested)
include .github/workflows/ci.yml
include .github/workflows/publish.yml

# If more workflows are added in the future, this will catch them:
include .github/workflows/*.yml

# Never ship generated metadata directories inside the sdist
recursive-exclude src/scatrans.egg-info *
prune build
prune dist
global-exclude *.pyc
global-exclude __pycache__/*
global-exclude *.egg-info
global-exclude *.egg-info/*

# Pre-split monorepo modules (scatrans/tl.py, scatrans/enrich.py) must not re-enter
# the tree: they shadow the real packages scatrans/tl/ and scatrans/enrich/ and
# would ship as unreachable dead code. Keep this exclusion even if files reappear.
global-exclude src/scatrans/tl.py
global-exclude src/scatrans/enrich.py
